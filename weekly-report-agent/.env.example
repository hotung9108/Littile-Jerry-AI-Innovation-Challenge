# Groq API key - lay tai https://console.groq.com/keys
GROQ_API_KEY=

# Model tren Groq. openai/gpt-oss-120b la model duoc Groq khuyen nghi hien tai
# (llama-3.3-70b-versatile da bi Groq deprecate). Co the doi sang openai/gpt-oss-20b
# neu can toc do nhanh hon / chi phi thap hon.
GROQ_MODEL=openai/gpt-oss-120b

# true = khong goi Groq that, dung bo tao noi dung mau de test pipeline offline
# false = goi that toi Groq API (can GROQ_API_KEY hop le)
MOCK_LLM=true

PORT=4000

# ==== Nguon du lieu bao cao hang ngay ====
# mock = dung du lieu gia lap (mac dinh, khong can mang)
# jira = goi that toi Jira REST API (can dien du cac bien JIRA_* ben duoi)
DATA_SOURCE=mock

# Chi can khi DATA_SOURCE=jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ
JIRA_JQL_EXTRA=

